{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@payment-banner-hider/*": [
        "standalone-scripts/payment-banner-hider/src/*"
      ]
    },
    "incremental": true,
    "tsBuildInfoFile": ".cache/tsbuildinfo/payment-banner-hider.tsbuildinfo"
  },
  "include": [
    "standalone-scripts/payment-banner-hider/src/**/*.ts",
    "standalone-scripts/payment-banner-hider/src/**/*.d.ts",
    "standalone-scripts/types/**/*.ts",
    "standalone-scripts/types/**/*.d.ts",
    "standalone-scripts/shared-version.ts",
    "version.json"
  ],
  "exclude": [
    "node_modules",
    "standalone-scripts/payment-banner-hider/dist"
  ]
}
