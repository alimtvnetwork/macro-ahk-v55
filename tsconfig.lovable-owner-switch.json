{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@lovable-owner-switch/*": [
        "standalone-scripts/lovable-owner-switch/src/*"
      ],
      "@lovable-common/*": [
        "standalone-scripts/lovable-common/src/*"
      ]
    },
    "incremental": true,
    "tsBuildInfoFile": ".cache/tsbuildinfo/lovable-owner-switch.tsbuildinfo"
  },
  "include": [
    "standalone-scripts/lovable-owner-switch/src/**/*.ts",
    "standalone-scripts/lovable-common/src/**/*.ts",
    "standalone-scripts/types/**/*.ts",
    "standalone-scripts/types/**/*.d.ts",
    "standalone-scripts/shared-version.ts",
    "version.json"
  ],
  "exclude": [
    "node_modules",
    "standalone-scripts/lovable-owner-switch/dist",
    "**/__tests__/**"
  ]
}
