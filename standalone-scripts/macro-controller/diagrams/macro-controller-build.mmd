%%{init: {'theme': 'dark', 'themeVariables': {'darkMode': true, 'background': '#222222', 'primaryColor': '#F5A623', 'primaryTextColor': '#1a1a1a', 'lineColor': '#666', 'fontSize': '13px'}}}%%

flowchart TD
    classDef root fill:#F5A623,stroke:#F5A623,color:#1a1a1a,stroke-width:0px,font-weight:bold,font-size:15px
    classDef emerald fill:#10B981,stroke:#10B981,color:#fff,stroke-width:2px,font-weight:bold
    classDef emeraldSub fill:#2a2a2a,stroke:#10B981,color:#e0e0e0,stroke-width:1px
    classDef sky fill:#0EA5E9,stroke:#0EA5E9,color:#fff,stroke-width:2px,font-weight:bold
    classDef skySub fill:#2a2a2a,stroke:#0EA5E9,color:#e0e0e0,stroke-width:1px
    classDef rose fill:#F43F5E,stroke:#F43F5E,color:#fff,stroke-width:2px,font-weight:bold
    classDef roseSub fill:#2a2a2a,stroke:#F43F5E,color:#e0e0e0,stroke-width:1px
    classDef amber fill:#F59E0B,stroke:#F59E0B,color:#1a1a1a,stroke-width:2px,font-weight:bold
    classDef amberSub fill:#2a2a2a,stroke:#F59E0B,color:#e0e0e0,stroke-width:1px
    classDef violet fill:#8B5CF6,stroke:#8B5CF6,color:#fff,stroke-width:2px,font-weight:bold
    classDef violetSub fill:#2a2a2a,stroke:#8B5CF6,color:#e0e0e0,stroke-width:1px

    %% Legend on the left
    subgraph LEGEND ["Color Legend"]
        direction TB
        L1(["Emerald = TypeScript Source"]):::emerald
        L2(["Sky = Config Files"]):::sky
        L3(["Rose = Build Pipeline"]):::rose
        L4(["Amber = dist/ Output"]):::amber
        L5(["Violet = Extension Deploy"]):::violet
    end
    style LEGEND fill:#1a1a1a,stroke:#555,color:#e0e0e0,stroke-width:1px

    LEGEND ~~~ ROOT

    ROOT(["Macro Controller Build"]):::root

    ROOT --> SRC & CFG & BUILD & DIST & EXT

    %% Source - Emerald
    SRC(["TypeScript Source"]):::emerald
    SRC --> ENTRY(["src/index.ts"]):::emeraldSub
    SRC --> MAIN(["src/macro-looping.ts"]):::emeraldSub
    SRC --> TYPES(["src/types.ts"]):::emeraldSub
    SRC --> UIMODS(["src/ui/ — 12 modules"]):::emeraldSub
    SRC --> INSTR(["src/instruction.ts"]):::emeraldSub

    %% Config - Sky
    CFG(["Config Files"]):::sky
    CFG --> JSON_CFG(["02-macro-controller-config.json"]):::skySub
    CFG --> THEME(["04-macro-theme.json"]):::skySub
    CFG --> TMPL(["templates/ — LESS + HTML"]):::skySub

    %% Build - Rose
    BUILD(["Build Pipeline"]):::rose
    BUILD --> VITE(["Vite IIFE Build"]):::roseSub
    BUILD --> TSC(["tsc --noEmit"]):::roseSub
    BUILD --> LESS_C(["LESS compile"]):::roseSub
    BUILD --> TMPL_C(["Template compile"]):::roseSub
    BUILD --> INSTR_C(["instruction.ts compile"]):::roseSub

    %% Output - Amber
    DIST(["dist/ Output"]):::amber
    DIST --> JS(["macro-looping.js — IIFE"]):::amberSub
    DIST --> CSS(["macro-controller.css"]):::amberSub
    DIST --> TMPL_J(["templates.json"]):::amberSub
    DIST --> INSTR_J(["instruction.json"]):::amberSub
    %% script-manifest.json removed — instruction.json is sole manifest

    %% Deploy - Violet
    EXT(["Extension Deploy"]):::violet
    EXT --> CPLUGIN(["copyProjectScripts plugin"]):::violetSub
    CPLUGIN --> EXT_DIR(["chrome-extension/dist/projects/"]):::violetSub
    EXT_DIR --> STORAGE(["chrome.storage.local"]):::violetSub
    STORAGE --> RESOLVER(["script-resolver via getURL"]):::violetSub
    RESOLVER --> PAGE(["Target page — IIFE executes"]):::violetSub

    %% Data flow
    ENTRY -.->|"compiles"| VITE
    VITE -.->|"outputs"| JS
    TMPL -.->|"compiles"| LESS_C
    LESS_C -.->|"outputs"| CSS
    INSTR -.->|"compiles"| INSTR_C
    INSTR_C -.->|"outputs"| INSTR_J
    JS -.->|"copied"| CPLUGIN
    JSON_CFG -.->|"MarcoConfig"| PAGE
    THEME -.->|"MarcoTheme"| PAGE
