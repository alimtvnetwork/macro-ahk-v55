%%{init: {'theme': 'dark', 'themeVariables': {'darkMode': true, 'background': '#222222', 'primaryColor': '#F5A623', 'primaryTextColor': '#1a1a1a', 'lineColor': '#666', 'fontSize': '13px'}}}%%

flowchart TD
    classDef root fill:#F5A623,stroke:#F5A623,color:#1a1a1a,stroke-width:0px,font-weight:bold,font-size:15px
    classDef emerald fill:#10B981,stroke:#10B981,color:#fff,stroke-width:2px,font-weight:bold
    classDef emeraldSub fill:#2a2a2a,stroke:#10B981,color:#e0e0e0,stroke-width:1px
    classDef sky fill:#0EA5E9,stroke:#0EA5E9,color:#fff,stroke-width:2px,font-weight:bold
    classDef skySub fill:#2a2a2a,stroke:#0EA5E9,color:#e0e0e0,stroke-width:1px
    classDef rose fill:#F43F5E,stroke:#F43F5E,color:#fff,stroke-width:2px,font-weight:bold
    classDef roseSub fill:#2a2a2a,stroke:#F43F5E,color:#e0e0e0,stroke-width:1px
    classDef amber fill:#F59E0B,stroke:#F59E0B,color:#1a1a1a,stroke-width:2px,font-weight:bold
    classDef amberSub fill:#2a2a2a,stroke:#F59E0B,color:#e0e0e0,stroke-width:1px
    classDef violet fill:#8B5CF6,stroke:#8B5CF6,color:#fff,stroke-width:2px,font-weight:bold
    classDef violetSub fill:#2a2a2a,stroke:#8B5CF6,color:#e0e0e0,stroke-width:1px
    classDef cyan fill:#06B6D4,stroke:#06B6D4,color:#fff,stroke-width:2px,font-weight:bold
    classDef cyanSub fill:#2a2a2a,stroke:#06B6D4,color:#e0e0e0,stroke-width:1px
    classDef coral fill:#FF6B6B,stroke:#FF6B6B,color:#fff,stroke-width:2px,font-weight:bold
    classDef coralSub fill:#2a2a2a,stroke:#FF6B6B,color:#e0e0e0,stroke-width:1px
    classDef teal fill:#14B8A6,stroke:#14B8A6,color:#fff,stroke-width:2px,font-weight:bold
    classDef tealSub fill:#2a2a2a,stroke:#14B8A6,color:#e0e0e0,stroke-width:1px

    %% Legend
    subgraph LEGEND ["Color Legend"]
        direction TB
        L0(["Teal = Cache Gate"]):::teal
        L1(["Emerald = Stage 0: Guard + Deps"]):::emerald
        L2(["Sky = Stage 1: Script Resolution"]):::sky
        L3(["Rose = Stage 2: Env Prep (parallel)"]):::rose
        L4(["Amber = Stage 3: Wrap + Prepare"]):::amber
        L5(["Violet = Stage 4: Execute (4-tier CSP)"]):::violet
        L6(["Cyan = Stage 5: Namespaces (parallel)"]):::cyan
        L7(["Coral = Post-Pipeline"]):::coral
    end
    style LEGEND fill:#1a1a1a,stroke:#555,color:#e0e0e0,stroke-width:1px

    LEGEND ~~~ ROOT
    ROOT(["Script Injection Pipeline"]):::root

    ROOT --> PRE & CACHE & S0 & S1 & S2 & S3 & S4 & S5 & POST

    %% Pre-Pipeline
    PRE(["Pre-Pipeline: User Trigger + Toast"]):::root
    PRE --> PRE_RUN(["Run Scripts (normal)"]):::emeraldSub
    PRE --> PRE_FORCE(["Force Run (forceReload=true)"]):::coralSub
    PRE_RUN --> PRE_TOAST(["Loading spinner toast"]):::emeraldSub
    PRE_FORCE --> PRE_TOAST

    %% Cache Gate
    CACHE(["Cache Decision Gate"]):::teal
    CACHE --> CACHE_HIT(["HIT: skip Stages 0-3, jump to Stage 4"]):::tealSub
    CACHE --> CACHE_MISS(["MISS: version mismatch or empty"]):::tealSub
    CACHE --> CACHE_FORCE(["FORCE: delete cache, full rebuild"]):::tealSub

    %% Stage 0
    S0(["Stage 0: Guard + Dependencies"]):::emerald
    S0 --> S0A(["0a: ensureBuiltinScriptsExist + self-heal"]):::emeraldSub
    S0A --> S0B(["0b: prependDependencyScripts (topo sort)"]):::emeraldSub

    %% Stage 1
    S1(["Stage 1: resolveInjectionRequestScripts"]):::sky
    S1 --> S1A(["Load code from chrome.storage.local"]):::skySub
    S1A --> S1B(["Load config JSON + theme JSON"]):::skySub
    S1B --> S1C(["Unresolvable = HARD ERROR"]):::skySub

    %% Stage 2
    S2(["Stage 2: Tab Env Prep -- Promise.all"]):::rose
    S2 --> S2A(["2a: bootstrapNamespaceRoot (MAIN)"]):::roseSub
    S2 --> S2B(["2b: ensureRelayInjected (ISOLATED)"]):::roseSub
    S2 --> S2C(["2c: seedTokensIntoTab"]):::roseSub

    %% Stage 3
    S3(["Stage 3: Wrap + Prepare"]):::amber
    S3 --> S3CSS{"CSS assets detected?"}
    S3CSS -- "Yes" --> S3SEQ(["Sequential: CSS then JS per script"]):::amberSub
    S3CSS -- "No" --> S3BATCH(["Batch: IIFE wrap + combine + cache"]):::amberSub

    %% Stage 4
    S4(["Stage 4: Execute -- 4-Tier CSP Fallback"]):::violet
    S4 --> S4T1(["Tier 1: MAIN World Blob (primary)"]):::violetSub
    S4T1 --> S4T2(["Tier 2: USER_SCRIPT (Chrome 135+)"]):::violetSub
    S4T2 --> S4T3(["Tier 3: ISOLATED Blob"]):::violetSub
    S4T3 --> S4T4(["Tier 4: ISOLATED Eval (last resort)"]):::violetSub

    %% Stage 5
    S5(["Stage 5: Namespaces (parallel with 3+4)"]):::cyan
    S5 --> S5A(["5a: Settings + llmGuide"]):::cyanSub
    S5 --> S5B(["5b: Projects per CodeName"]):::cyanSub

    %% Post-Pipeline
    POST(["Post-Pipeline"]):::coral
    POST --> POST_LOG(["Log mirror: DevTools + SQLite + OPFS"]):::coralSub
    POST_LOG --> POST_BUDGET(["Performance budget check"]):::coralSub
    POST_BUDGET --> POST_VERIFY(["Verify 6 post-injection globals"]):::coralSub
    POST_VERIFY --> POST_TOAST(["Final toast: success / warn / error"]):::coralSub

    %% Sequential flow
    PRE_TOAST -.->|"check cache"| CACHE
    CACHE_HIT -.->|"cached payload"| S4
    CACHE_MISS -.->|"full pipeline"| S0
    CACHE_FORCE -.->|"cleared"| S0
    S0B -.->|"ordered scripts"| S1
    S1C -.->|"resolved"| S2
    S2A & S2B & S2C -.->|"env ready"| S3
    S3SEQ -.->|"injected"| S4
    S3BATCH -.->|"combined payload"| S4
    S4T1 -.->|"results"| S5
    S5A & S5B -.->|"populated"| POST
