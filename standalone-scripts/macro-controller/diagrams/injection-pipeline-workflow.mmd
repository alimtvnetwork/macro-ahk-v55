graph TD
    classDef userAction fill:#3B82F6,color:#fff,stroke:#2563EB,stroke-width:2px
    classDef stage fill:#8B5CF6,color:#fff,stroke:#7C3AED,stroke-width:2px
    classDef parallel fill:#EC4899,color:#fff,stroke:#DB2777,stroke-width:2px
    classDef process fill:#10B981,color:#fff,stroke:#059669,stroke-width:2px
    classDef decision fill:#F59E0B,color:#000,stroke:#D97706,stroke-width:2px
    classDef output fill:#EF4444,color:#fff,stroke:#DC2626,stroke-width:2px
    classDef fallback fill:#F97316,color:#fff,stroke:#EA580C,stroke-width:2px
    classDef logNode fill:#06B6D4,color:#fff,stroke:#0891B2,stroke-width:2px
    classDef errorNode fill:#DC2626,color:#fff,stroke:#B91C1C,stroke-width:2px
    classDef note fill:#334155,color:#CBD5E1,stroke:#475569,stroke-width:1px
    classDef cache fill:#14B8A6,color:#fff,stroke:#0D9488,stroke-width:2px

    A["User clicks Run Scripts in popup"]:::userAction
    AF["User clicks Force Run Scripts in popup"]:::userAction

    A --> B["handleInjectScripts -- Pipeline Orchestrator<br/>mode = normal"]:::stage
    AF --> BF["handleInjectScripts -- Pipeline Orchestrator<br/>mode = forceReload"]:::stage

    B -. "1. Record performance.now start<br/>2. Query active tab via chrome.tabs<br/>3. Log INFO: pipeline START tabId, url, scriptCount" .-> BNOTE["Orchestrator entry point.<br/>All stages sequential except<br/>where marked parallel."]:::note
    BF -. "Same orchestrator but forceReload=true.<br/>LOG INFO: FORCE RUN -- cache bypassed by user." .-> BFNOTE["Force Run always rebuilds<br/>from scratch. Useful when<br/>cached data seems stale."]:::note

    B --> TOAST["Inject loading spinner toast into tab<br/>Fixed overlay: spinner + Injecting scripts..."]:::process
    BF --> TOAST
    TOAST -. "Visible during entire pipeline.<br/>Replaced by result toast at end." .-> TOASTNOTE["User sees immediate feedback<br/>that injection has started."]:::note

    %% ===== FORCE RUN BYPASS =====
    TOAST --> FORCECHECK{"forceReload flag set?"}:::decision
    FORCECHECK -- "Yes: Force Run" --> FORCECLEAR["Delete cached entry if exists<br/>LOG: Force reload -- cache cleared"]:::cache
    FORCECLEAR --> GUARD
    FORCECHECK -- "No: Normal Run" --> CACHEVER

    %% ===== CACHE GATE =====
    CACHEVER["Read current version from manifest"]:::cache
    CACHEVER --> CACHE{"Cache Decision Gate<br/>IndexedDB: marco_injection_cache<br/>Lookup by version key"}:::cache
    CACHE -. "Key = manifest version string only.<br/>No hashing. No content comparison.<br/>Single entry for entire payload." .-> CACHENOTE["Version source:<br/>chrome.runtime.getManifest().version<br/>Same as EXTENSION_VERSION constant."]:::note

    CACHE -- "HIT: version matches<br/>LOG: cache HIT version=X.Y.Z" --> CACHEFAST["Skip Stages 0-3<br/>Use cached wrapped payload"]:::cache
    CACHEFAST --> EXEC

    CACHE -- "MISS: version mismatch<br/>LOG: cached=A.B.C current=X.Y.Z" --> GUARD
    CACHE -- "MISS: cache empty or removed<br/>LOG: no cached payload found" --> GUARD
    CACHE -- "CORRUPT: payload unreadable<br/>LOG ERROR: Path: IndexedDB key=ver<br/>Missing: valid payload string<br/>Reason: field undefined or schema drift" --> GUARD

    %% ===== STAGE 0a =====
    GUARD["Stage 0a: ensureBuiltinScriptsExist"]:::stage
    GUARD -. "1. Read required built-in script IDs from manifest<br/>2. Check each exists in chrome.storage.local<br/>3. LOG INFO per found script<br/>4. On missing: attempt self-heal from bundled /scripts/" .-> GUARDNOTE["Built-in scripts: SDK preamble,<br/>relay installer, namespace bootstrap.<br/>Self-heal from bundled /scripts/."]:::note
    GUARD --> GUARDFAIL{"Any built-in still missing<br/>after self-heal?"}:::decision
    GUARDFAIL -- "Yes" --> GUARDERR["HARD ERROR per missing script.<br/>LOG ERROR:<br/>  Path: chrome.storage.local key<br/>  Missing: script ID + bundled fallback path<br/>  Reason: storage empty AND fallback file<br/>  missing from extension package"]:::errorNode
    GUARDFAIL -- "No" --> DEPS
    GUARDERR --> DEPS

    %% ===== STAGE 0b =====
    DEPS["Stage 0b: prependDependencyScripts"]:::stage
    DEPS -. "1. Read dependsOn from project config<br/>2. Build DAG, topological sort<br/>3. Prepend deps before dependents<br/>4. LOG INFO: resolved order" .-> DEPSNOTE["Example: if B depends on A,<br/>order becomes A, B, ...<br/>Missing dep = ERROR for both."]:::note
    DEPS --> DEPSFAIL{"Any dependency missing?"}:::decision
    DEPSFAIL -- "Yes" --> DEPSERR["ERROR per missing dependency.<br/>LOG ERROR:<br/>  Path: project.config.json dependsOn<br/>  Missing: script ID required by dependent<br/>  Reason: declared dependency not found<br/>  in storage or script manifest"]:::errorNode
    DEPSFAIL -- "No" --> RESOLVE
    DEPSERR --> RESOLVE

    %% ===== STAGE 1 =====
    RESOLVE["Stage 1: resolveInjectionRequestScripts"]:::stage
    RESOLVE -. "1. Load code from chrome.storage.local<br/>2. Load config JSON + theme JSON if bound<br/>3. Unresolvable = HARD ERROR, not skip<br/>4. LOG ERROR per failed script with full context" .-> RESOLVENOTE["Error reasons: code_not_found,<br/>config_missing, type_mismatch.<br/>Zero resolved = pipeline halts."]:::note

    RESOLVE --> EMPTY{"Any scripts resolved?"}:::decision
    EMPTY -- "No" --> EARLYERR["Pipeline halts. Error toast.<br/>LOG ERROR:<br/>  Path: injection request tabId + url<br/>  Missing: any resolvable script 0 of N<br/>  Reason: all scripts failed resolution<br/>  see per-script errors above"]:::errorNode
    EARLYERR --> TOASTFINAL
    EMPTY -- "Yes" --> PARALLEL1

    %% ===== STAGE 2 =====
    PARALLEL1["Stage 2: Tab Environment Prep -- Promise.all"]:::parallel

    PARALLEL1 --> P1A["2a: bootstrapNamespaceRoot"]:::process
    P1A -. "Create window.RiseupAsiaMacroExt in MAIN world.<br/>MAIN world = page JS context, shares window.<br/>If CSP blocks: health=DEGRADED.<br/>LOG ERROR: Path: chrome.scripting tabId MAIN<br/>Missing: window.RiseupAsiaMacroExt<br/>Reason: CSP script-src blocks inline execution" .-> P1ANOTE["Root namespace MUST exist<br/>before any script runs."]:::note

    PARALLEL1 --> P1B["2b: ensureRelayInjected"]:::process
    P1B -. "Relay = content script in ISOLATED world.<br/>Bridges page postMessage to chrome.runtime.<br/>Duplicate check: __marcoRelayInstalled marker.<br/>If marker exists = skip. If not = inject.<br/>LOG ERROR on fail: Path: chrome.scripting ISOLATED<br/>Missing: relay marker<br/>Reason: restricted page or permission denied" .-> P1BNOTE["ISOLATED world: separate JS env.<br/>Shares DOM but not window vars.<br/>Relay uses postMessage as bridge."]:::note

    PARALLEL1 --> P1C["2c: seedTokensIntoTab"]:::process
    P1C -. "1. Read marco_bearer_token + timestamp from storage<br/>2. If age under TTL 2min: use stored token<br/>3. If expired: read cookie again, store new timestamp<br/>4. Write token to tab localStorage via MAIN world<br/>LOG ERROR on fail: Path: storage key + cookie domain<br/>Missing: JWT bearer token<br/>Reason: storage empty AND cookie null" .-> P1CNOTE["Simple flow: read cookie,<br/>store with timestamp,<br/>check expiry, re-read if stale."]:::note

    P1A --> BOOTDONE
    P1B --> BOOTDONE
    P1C --> BOOTDONE
    BOOTDONE["All 3 prep tasks complete"]:::process

    %% ===== STAGE 3 =====
    BOOTDONE --> INJECTCHECK{"Any scripts have CSS assets?"}:::decision

    INJECTCHECK -- "Yes: CSS detected" --> SEQ["Sequential Injection Mode"]:::fallback
    SEQ -. "CSS must load BEFORE its JS runs.<br/>Each script injected individually.<br/>LOG INFO: CSS detected, sequential mode." .-> SEQNOTE["CSS-first ensures styles are<br/>available when script creates UI."]:::note
    SEQ --> CSSINJECT["For each script with CSS:<br/>1. chrome.scripting.insertCSS -- inject stylesheet<br/>2. Wait for CSS load<br/>3. Wrap JS with try-catch IIFE<br/>4. Execute wrapped JS"]:::process
    CSSINJECT -. "LOG INFO: CSS injected path for scriptId<br/>LOG INFO: JS executed for scriptId" .-> CSSNOTE["If script has no CSS,<br/>inject its JS in same order<br/>but skip CSS step."]:::note
    CSSINJECT --> RESULTS

    INJECTCHECK -- "No CSS" --> BATCH["Stage 3: Batch Mode"]:::stage
    BATCH -. "Why batch? One chrome.scripting.executeScript<br/>call instead of N separate calls. Reduces<br/>round-trips between background and tab." .-> BATCHNOTE["Only used when no scripts<br/>need CSS assets."]:::note
    BATCH --> WRAP["Wrap each script in try-catch IIFE"]:::process
    WRAP -. "Each script gets:<br/>1. Own function scope -- no var leaks<br/>2. try-catch -- one failure wont break others<br/>3. SDK preamble -- marco helper access<br/>4. Error reporting via postMessage" .-> WRAPNOTE["Before: raw code.<br/>After: IIFE + try + code + catch + report"]:::note
    WRAP --> COMBINE["Join all wrapped IIFEs into one string:<br/>IIFE1 + newline + IIFE2 + newline + IIFE3<br/>Single string passed to Stage 4"]:::process
    COMBINE -. "LOG INFO: Combined payload size N bytes<br/>LOG INFO: N scripts prepared" .-> COMBINENOTE["One string = one executeScript call<br/>= one IPC round-trip to tab"]:::note

    COMBINE --> STORECACHE["Store payload in IndexedDB<br/>key = version string, no hashing"]:::cache
    STORECACHE -. "LOG: Stored payload for version=X.Y.Z, size=N bytes<br/>Cache cleared automatically by 3 layers:" .-> STORENOTE["Layer 1: chrome.runtime.onInstalled clears cache<br/>Layer 2: Version key mismatch auto-rebuilds<br/>Layer 3: PowerShell run.ps1 as safety net"]:::note
    STORECACHE --> EXEC

    %% ===== STAGE 4 =====
    EXEC["Stage 4: Execute -- 4-Tier CSP Fallback"]:::stage
    EXEC -. "CSP = Content Security Policy.<br/>Example: script-src self cdn.example.com<br/>Our injected code is not from those sources.<br/>Each tier tried sequentially until one succeeds." .-> CSPNOTE["Extension must use methods<br/>that work around CSP.<br/>4 tiers tried in order."]:::note

    EXEC --> T1["Tier 1: MAIN World Blob (primary)"]:::process
    T1 -. "1. Code string to Blob type=text/javascript<br/>2. URL.createObjectURL gives blob: URL<br/>3. Create script tag, src=blob URL<br/>4. Append to document.documentElement<br/>5. Browser executes in MAIN world<br/>6. Revoke blob URL after execution" .-> T1NOTE["MAIN world = page JS context.<br/>Full access to window, DOM, page globals.<br/>Blob URLs treated as same-origin by browser."]:::note

    T1 --> T1UI["UI Injection Flow:<br/>Script runs in page context.<br/>MacroController class initializes.<br/>Creates UI container in DOM.<br/>UI becomes visible to user."]:::process

    T1UI --> T1CHECK{"Tier 1 succeeded?"}:::decision
    T1CHECK -- "Yes" --> RESULTS
    T1CHECK -- "No: CSP blocked blob URL" --> T2

    T2["Tier 2: USER_SCRIPT (Chrome 135+)"]:::fallback
    T2 -. "Uses chrome.userScripts.execute API.<br/>Available in Chrome 135 and later.<br/>Runs in USER_SCRIPT world.<br/>LOG WARN: Falling back to USER_SCRIPT tier." .-> T2NOTE["USER_SCRIPT world has near-MAIN<br/>access but bypasses strict CSP.<br/>health=DEGRADED if used."]:::note

    T2 --> T2CHECK{"Tier 2 succeeded?"}:::decision
    T2CHECK -- "Yes" --> RESULTS
    T2CHECK -- "No: API unavailable or blocked" --> T3

    T3["Tier 3: ISOLATED World Blob"]:::fallback
    T3 -. "Same blob technique as Tier 1<br/>but executed in ISOLATED world.<br/>Cannot see page vars.<br/>LOG WARN: Falling back to ISOLATED Blob." .-> T3NOTE["ISOLATED world: separate JS env.<br/>Shares DOM but not window vars.<br/>Most macro features degraded."]:::note

    T3 --> T3CHECK{"Tier 3 succeeded?"}:::decision
    T3CHECK -- "Yes" --> RESULTS
    T3CHECK -- "No: ISOLATED blob also blocked" --> T4

    T4["Tier 4: ISOLATED Eval (last resort)"]:::fallback
    T4 -. "Direct eval in ISOLATED world.<br/>LOG ERROR:<br/>  Path: all prior tiers on tabId<br/>  Missing: any working injection method<br/>  Reason: CSP blocks blob in both worlds<br/>  Fallback: eval -- health=DEGRADED" .-> T4NOTE["Last resort. If this fails,<br/>injection is impossible on this page.<br/>All 4 tiers report in error message."]:::note

    T4 --> T4CHECK{"Tier 4 succeeded?"}:::decision
    T4CHECK -- "Yes" --> RESULTS
    T4CHECK -- "No: all 4 tiers failed" --> ALLFAIL["All injection tiers failed.<br/>LOG ERROR: complete tier results.<br/>health=ERROR"]:::errorNode
    ALLFAIL --> RESULTS

    %% ===== RESULTS =====
    RESULTS["Collect InjectionResult per script:<br/>scriptId, success, durationMs,<br/>injectionPath used, error if any"]:::stage

    %% ===== STAGE 5 =====
    RESULTS --> NS["Stage 5: Populate Data Namespaces -- Parallel"]:::parallel
    NS -. "Root object RiseupAsiaMacroExt exists from Stage 2a.<br/>Stage 5 fills it with runtime DATA:<br/>settings values and project variables." .-> NSNOTE["Scripts access data lazily via<br/>marco.whenReady or on user interaction,<br/>not synchronously at load time."]:::note

    NS --> NS_SET["5a: Settings + llmGuide<br/>RiseupAsiaMacroExt.Settings = values"]:::process
    NS --> NS_PROJ["5b: Projects per CodeName<br/>RiseupAsiaMacroExt.Projects.X = vars"]:::process
    NS_SET -. "LOG INFO: Settings populated N keys<br/>On fail LOG ERROR:<br/>  Path: chrome.scripting MAIN world<br/>  Missing: Settings object in namespace<br/>  Reason: CSP blocked, health=DEGRADED" .-> NSSETNOTE["If CSP blocks: DEGRADED + ERROR"]:::note
    NS_PROJ -. "LOG INFO: Projects populated: A, B" .-> NSPROJNOTE["Each project gets a vars Map<br/>for console variable access."]:::note

    NS_SET --> POST
    NS_PROJ --> POST

    %% ===== POST PIPELINE =====
    POST["Post-Pipeline Processing"]:::stage

    POST --> MIRROR["Mirror all pipeline logs to:<br/>1. Tab DevTools via console.groupCollapsed<br/>2. Extension SQLite via recordInjection<br/>3. OPFS session log"]:::logNode

    POST --> BUDGET{"Total time exceeds 2000ms?"}:::decision
    BUDGET -- "Yes" --> BUDGETWARN["LOG WARN: PERFORMANCE BUDGET EXCEEDED"]:::logNode
    BUDGET -- "No" --> VERIFY
    BUDGETWARN --> VERIFY

    VERIFY["Verify 6 post-injection globals"]:::stage
    VERIFY -. "Each missing global gets LOG WARN:<br/>  Path: window.globalName or DOM selector<br/>  Missing: expected object or element<br/>  Reason: likely cause from earlier stage" .-> VERIFYNOTE["Globals checked:<br/>1. window.marco<br/>2. window.RiseupAsiaMacroExt<br/>3. window.MacroController<br/>4. api.mc<br/>5. UI container in DOM<br/>6. __macroExtInjected flag"]:::note

    VERIFY --> TOASTFINAL{"Determine final toast"}:::decision
    TOASTFINAL -- "All pass" --> TSUCCESS["SUCCESS toast green:<br/>N scripts injected successfully"]:::process
    TOASTFINAL -- "Warnings" --> TWARN["WARNING toast amber:<br/>N injected, M warnings"]:::fallback
    TOASTFINAL -- "Failure" --> TERROR["ERROR toast red:<br/>Injection failed: reason"]:::errorNode

    TSUCCESS --> DONE
    TWARN --> DONE
    TERROR --> DONE
    DONE["Return InjectionResult array to popup"]:::userAction