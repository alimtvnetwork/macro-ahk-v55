%%{init: {'theme': 'dark', 'themeVariables': {'darkMode': true, 'background': '#222222', 'primaryColor': '#F5A623', 'primaryTextColor': '#1a1a1a', 'lineColor': '#666', 'fontSize': '13px'}}}%%

flowchart TD
    classDef root fill:#F5A623,stroke:#F5A623,color:#1a1a1a,stroke-width:0px,font-weight:bold,font-size:15px
    classDef emerald fill:#10B981,stroke:#10B981,color:#fff,stroke-width:2px,font-weight:bold
    classDef emeraldSub fill:#2a2a2a,stroke:#10B981,color:#e0e0e0,stroke-width:1px
    classDef sky fill:#0EA5E9,stroke:#0EA5E9,color:#fff,stroke-width:2px,font-weight:bold
    classDef skySub fill:#2a2a2a,stroke:#0EA5E9,color:#e0e0e0,stroke-width:1px
    classDef rose fill:#F43F5E,stroke:#F43F5E,color:#fff,stroke-width:2px,font-weight:bold
    classDef roseSub fill:#2a2a2a,stroke:#F43F5E,color:#e0e0e0,stroke-width:1px
    classDef amber fill:#F59E0B,stroke:#F59E0B,color:#1a1a1a,stroke-width:2px,font-weight:bold
    classDef amberSub fill:#2a2a2a,stroke:#F59E0B,color:#e0e0e0,stroke-width:1px

    %% Legend on the left
    subgraph LEGEND ["Color Legend"]
        direction TB
        L1(["Emerald = Public Methods"]):::emerald
        L2(["Sky = Token Resolution with TTL"]):::sky
        L3(["Rose = Cookie Fallback"]):::rose
        L4(["Amber = Component Consumers"]):::amber
    end
    style LEGEND fill:#1a1a1a,stroke:#555,color:#e0e0e0,stroke-width:1px

    LEGEND ~~~ ROOT

    ROOT(["Auth Bridge Service"]):::root

    ROOT --> API & RESOLVE & COOKIE & CONSUMERS

    %% Public API - Emerald
    API(["Public Methods"]):::emerald
    API --> M1(["getBearerToken - returns cached or fresh token"]):::emeraldSub
    API --> M2(["getRawToken - returns localStorage token as-is"]):::emeraldSub
    API --> M3(["getTokenAge - returns ms since last save"]):::emeraldSub

    %% Token Resolution - Sky
    RESOLVE(["Token Resolution: getBearerToken"]):::sky
    M1 --> RESOLVE
    RESOLVE --> R1(["Read token + savedAt from localStorage"]):::skySub
    R1 --> R2(["Is token present and age less than TTL?"]):::skySub
    R2 -->|"Yes: fresh"| R3(["Return cached token immediately"]):::skySub
    R2 -->|"No: stale or missing"| COOKIE

    %% Cookie Fallback - Rose
    COOKIE(["Cookie Fallback"]):::rose
    COOKIE --> C1(["Read lovable-session-id cookie"]):::roseSub
    C1 --> C2(["Save token + timestamp to localStorage"]):::roseSub
    C2 --> C3(["Return fresh token"]):::roseSub

    %% Consumers - Amber
    CONSUMERS(["Component Consumers"]):::amber
    R3 --> CONSUMERS
    C3 --> CONSUMERS
    CONSUMERS --> U1(["Credits / Workspace Loader"]):::amberSub
    CONSUMERS --> U2(["Macro Controller"]):::amberSub
    CONSUMERS --> U3(["Any future component"]):::amberSub
    U1 --> U4(["Component provides URL + body"]):::amberSub
    U4 --> U5(["Auth Bridge provides bearer token"]):::amberSub
    U5 --> U6(["Component makes API request"]):::amberSub
