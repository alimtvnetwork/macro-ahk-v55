%%{init: {'theme': 'dark', 'themeVariables': {'darkMode': true, 'background': '#222222', 'primaryColor': '#F5A623', 'primaryTextColor': '#1a1a1a', 'lineColor': '#666', 'fontSize': '13px'}}}%%

flowchart TD
    classDef root fill:#F5A623,stroke:#F5A623,color:#1a1a1a,stroke-width:0px,font-weight:bold,font-size:15px
    classDef emerald fill:#10B981,stroke:#10B981,color:#fff,stroke-width:2px,font-weight:bold
    classDef emeraldSub fill:#2a2a2a,stroke:#10B981,color:#e0e0e0,stroke-width:1px
    classDef sky fill:#0EA5E9,stroke:#0EA5E9,color:#fff,stroke-width:2px,font-weight:bold
    classDef skySub fill:#2a2a2a,stroke:#0EA5E9,color:#e0e0e0,stroke-width:1px
    classDef rose fill:#F43F5E,stroke:#F43F5E,color:#fff,stroke-width:2px,font-weight:bold
    classDef roseSub fill:#2a2a2a,stroke:#F43F5E,color:#e0e0e0,stroke-width:1px
    classDef amber fill:#F59E0B,stroke:#F59E0B,color:#1a1a1a,stroke-width:2px,font-weight:bold
    classDef amberSub fill:#2a2a2a,stroke:#F59E0B,color:#e0e0e0,stroke-width:1px
    classDef violet fill:#8B5CF6,stroke:#8B5CF6,color:#fff,stroke-width:2px,font-weight:bold
    classDef violetSub fill:#2a2a2a,stroke:#8B5CF6,color:#e0e0e0,stroke-width:1px
    classDef cyan fill:#06B6D4,stroke:#06B6D4,color:#fff,stroke-width:2px,font-weight:bold
    classDef cyanSub fill:#2a2a2a,stroke:#06B6D4,color:#e0e0e0,stroke-width:1px

    %% Legend on the left
    subgraph LEGEND ["Color Legend"]
        direction TB
        L1(["Emerald = Page Scripts MAIN World"]):::emerald
        L2(["Sky = Content Script ISOLATED World"]):::sky
        L3(["Rose = Background Service Worker"]):::rose
        L4(["Amber = Message Channels"]):::amber
        L5(["Violet = Request Types"]):::violet
        L6(["Cyan = Response Flow"]):::cyan
    end
    style LEGEND fill:#1a1a1a,stroke:#555,color:#e0e0e0,stroke-width:1px

    LEGEND ~~~ ROOT

    ROOT(["Message Relay Architecture"]):::root

    ROOT --> PAGE & CS & BG & CHANNELS & REQUESTS & RESPONSES

    %% Page Scripts - Emerald
    PAGE(["Page Scripts — MAIN World"]):::emerald
    PAGE --> P1(["MacroController IIFE"]):::emeraldSub
    PAGE --> P2(["RiseupAsiaMacroExt Namespace"]):::emeraldSub
    PAGE --> P3(["CreditMonitor Module"]):::emeraldSub
    P1 --> P4(["PostMessage to Window"]):::emeraldSub
    P2 --> P5(["Await response via MessageEvent"]):::emeraldSub

    %% Content Script - Sky
    CS(["Content Script — ISOLATED World"]):::sky
    CS --> C1(["RelayContentScript"]):::skySub
    C1 --> C2(["Listen: Window PostMessage"]):::skySub
    C1 --> C3(["Listen: Chrome Runtime OnMessage"]):::skySub
    C2 --> C4(["Forward to Background via Chrome.Runtime"]):::skySub
    C3 --> C5(["Forward to Page via Window.PostMessage"]):::skySub

    %% Background Service Worker - Rose
    BG(["Background Service Worker"]):::rose
    BG --> B1(["Chrome.Runtime.OnMessage Listener"]):::roseSub
    B1 --> B2(["Route by MessageType"]):::roseSub
    B2 --> B3(["Execute handler: SQLite, Storage, Inject"]):::roseSub
    B3 --> B4(["SendResponse back to Content Script"]):::roseSub

    %% Message Channels - Amber
    CHANNELS(["Message Channels"]):::amber
    CHANNELS --> CH1(["Page to CS: Window.PostMessage"]):::amberSub
    CHANNELS --> CH2(["CS to BG: Chrome.Runtime.SendMessage"]):::amberSub
    CHANNELS --> CH3(["BG to CS: SendResponse callback"]):::amberSub
    CHANNELS --> CH4(["CS to Page: Window.PostMessage"]):::amberSub

    %% Request Types - Violet
    REQUESTS(["Request Types"]):::violet
    REQUESTS --> R1(["GetPrompts — fetch prompt data"]):::violetSub
    REQUESTS --> R2(["DynamicRequire — inject script"]):::violetSub
    REQUESTS --> R3(["GetCredits — workspace API call"]):::violetSub
    REQUESTS --> R4(["DbQuery — SQLite read/write"]):::violetSub
    REQUESTS --> R5(["GetSettings — extension config"]):::violetSub

    %% Response Flow - Cyan
    RESPONSES(["Response Flow"]):::cyan
    RESPONSES --> S1(["BG resolves data or error"]):::cyanSub
    S1 --> S2(["SendResponse with Result envelope"]):::cyanSub
    S2 --> S3(["CS relays Result via PostMessage"]):::cyanSub
    S3 --> S4(["Page matches CorrelationId"]):::cyanSub
    S4 --> S5(["Promise resolves in caller"]):::cyanSub

    %% Cross-flow links
    P4 -.->|"PostMessage"| C2
    C4 -.->|"Chrome.Runtime"| B1
    B4 -.->|"SendResponse"| C3
    C5 -.->|"PostMessage"| P5
    R1 -.->|"routed by"| B2
    S2 -.->|"via relay"| C5
