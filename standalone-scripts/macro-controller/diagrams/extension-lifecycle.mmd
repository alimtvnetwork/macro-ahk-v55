%%{init: {'theme': 'dark', 'themeVariables': {'darkMode': true, 'background': '#222222', 'primaryColor': '#F5A623', 'primaryTextColor': '#1a1a1a', 'lineColor': '#666', 'fontSize': '13px'}}}%%

flowchart TD
    classDef root fill:#F5A623,stroke:#F5A623,color:#1a1a1a,stroke-width:0px,font-weight:bold,font-size:15px
    classDef emerald fill:#10B981,stroke:#10B981,color:#fff,stroke-width:2px,font-weight:bold
    classDef emeraldSub fill:#2a2a2a,stroke:#10B981,color:#e0e0e0,stroke-width:1px
    classDef sky fill:#0EA5E9,stroke:#0EA5E9,color:#fff,stroke-width:2px,font-weight:bold
    classDef skySub fill:#2a2a2a,stroke:#0EA5E9,color:#e0e0e0,stroke-width:1px
    classDef rose fill:#F43F5E,stroke:#F43F5E,color:#fff,stroke-width:2px,font-weight:bold
    classDef roseSub fill:#2a2a2a,stroke:#F43F5E,color:#e0e0e0,stroke-width:1px
    classDef amber fill:#F59E0B,stroke:#F59E0B,color:#1a1a1a,stroke-width:2px,font-weight:bold
    classDef amberSub fill:#2a2a2a,stroke:#F59E0B,color:#e0e0e0,stroke-width:1px
    classDef violet fill:#8B5CF6,stroke:#8B5CF6,color:#fff,stroke-width:2px,font-weight:bold
    classDef violetSub fill:#2a2a2a,stroke:#8B5CF6,color:#e0e0e0,stroke-width:1px
    classDef cyan fill:#06B6D4,stroke:#06B6D4,color:#fff,stroke-width:2px,font-weight:bold
    classDef cyanSub fill:#2a2a2a,stroke:#06B6D4,color:#e0e0e0,stroke-width:1px

    %% Legend on the left
    subgraph LEGEND ["Color Legend"]
        direction TB
        L1(["Emerald = Install + Bootstrap"]):::emerald
        L2(["Sky = Tab Navigation"]):::sky
        L3(["Rose = Auth + Token Seeding"]):::rose
        L4(["Amber = Script Injection"]):::amber
        L5(["Violet = Runtime Execution"]):::violet
        L6(["Cyan = User Interaction"]):::cyan
    end
    style LEGEND fill:#1a1a1a,stroke:#555,color:#e0e0e0,stroke-width:1px

    LEGEND ~~~ ROOT

    ROOT(["Extension Lifecycle"]):::root

    ROOT --> INSTALL & NAV & AUTH & INJECT & RUNTIME & UI

    %% Phase 1: Install + Bootstrap - Emerald
    INSTALL(["Install + Bootstrap"]):::emerald
    INSTALL --> I1(["Chrome loads manifest.json V3"]):::emeraldSub
    I1 --> I2(["Service worker registers"]):::emeraldSub
    I2 --> I3(["SQLite databases initialized"]):::emeraldSub
    I3 --> I4(["Seed projects + scripts from storage"]):::emeraldSub
    I4 --> I5(["Context menus created"]):::emeraldSub

    %% Phase 2: Tab Navigation - Sky
    NAV(["Tab Navigation Trigger"]):::sky
    NAV --> N1(["onUpdated: status complete"]):::skySub
    N1 --> N2(["Match URL against project rules"]):::skySub
    N2 --> N3(["Resolve matched scripts"]):::skySub
    N3 --> N4(["Topological dependency sort"]):::skySub

    %% Phase 3: Auth + Token Seeding - Rose
    AUTH(["Auth + Token Seeding"]):::rose
    AUTH --> A1(["authBridge.getBearerToken"]):::roseSub
    A1 --> A2(["Check localStorage TTL cache"]):::roseSub
    A2 --> A3(["Fallback: read Lovable session cookie"]):::roseSub
    A3 --> A4(["Seed token into page via relay CS"]):::roseSub

    %% Phase 4: Script Injection - Amber
    INJECT(["Script Injection"]):::amber
    INJECT --> J1(["Bootstrap RiseupAsiaMacroExt namespace"]):::amberSub
    J1 --> J2(["IIFE wrap each script + SDK preamble"]):::amberSub
    J2 --> J3(["injectWithCspFallback MAIN world"]):::amberSub
    J3 --> J4(["Register Settings + Project namespaces"]):::amberSub
    J4 --> J5(["CSP blocked: DEGRADED health state"]):::amberSub

    %% Phase 5: Runtime Execution - Violet
    RUNTIME(["Runtime Execution"]):::violet
    RUNTIME --> R1(["Scripts execute in page context"]):::violetSub
    R1 --> R2(["marco SDK: log, store, events"]):::violetSub
    R2 --> R3(["Dynamic loading: require API"]):::violetSub
    R3 --> R4(["Background validates + injects target"]):::violetSub
    R4 --> R5(["SQLite audit logging"]):::violetSub

    %% Phase 6: User Interaction - Cyan
    UI(["User Interaction"]):::cyan
    UI --> U1(["Popup: status, credits, script list"]):::cyanSub
    UI --> U2(["Context menu: Run, Re-inject, Export"]):::cyanSub
    U2 --> U3(["Options page: project + config editor"]):::cyanSub
    U3 --> U4(["Credit check via authBridge + API"]):::cyanSub

    %% Cross-phase flow
    I5 -.->|"ready for navigation"| NAV
    N4 -.->|"scripts resolved"| AUTH
    A4 -.->|"tokens available"| INJECT
    J4 -.->|"namespace live"| RUNTIME
    R2 -.->|"SDK events"| UI
    U2 -.->|"re-inject trigger"| NAV
