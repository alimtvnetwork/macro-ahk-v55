%%{init: {'theme': 'dark', 'themeVariables': {'darkMode': true, 'background': '#222222', 'primaryColor': '#F5A623', 'primaryTextColor': '#1a1a1a', 'lineColor': '#666', 'fontSize': '13px'}}}%%

flowchart TD
    classDef root fill:#F5A623,stroke:#F5A623,color:#1a1a1a,stroke-width:0px,font-weight:bold,font-size:15px
    classDef emerald fill:#10B981,stroke:#10B981,color:#fff,stroke-width:2px,font-weight:bold
    classDef emeraldSub fill:#2a2a2a,stroke:#10B981,color:#e0e0e0,stroke-width:1px
    classDef sky fill:#0EA5E9,stroke:#0EA5E9,color:#fff,stroke-width:2px,font-weight:bold
    classDef skySub fill:#2a2a2a,stroke:#0EA5E9,color:#e0e0e0,stroke-width:1px
    classDef rose fill:#F43F5E,stroke:#F43F5E,color:#fff,stroke-width:2px,font-weight:bold
    classDef roseSub fill:#2a2a2a,stroke:#F43F5E,color:#e0e0e0,stroke-width:1px
    classDef amber fill:#F59E0B,stroke:#F59E0B,color:#1a1a1a,stroke-width:2px,font-weight:bold
    classDef amberSub fill:#2a2a2a,stroke:#F59E0B,color:#e0e0e0,stroke-width:1px
    classDef violet fill:#8B5CF6,stroke:#8B5CF6,color:#fff,stroke-width:2px,font-weight:bold
    classDef violetSub fill:#2a2a2a,stroke:#8B5CF6,color:#e0e0e0,stroke-width:1px
    classDef cyan fill:#06B6D4,stroke:#06B6D4,color:#fff,stroke-width:2px,font-weight:bold
    classDef cyanSub fill:#2a2a2a,stroke:#06B6D4,color:#e0e0e0,stroke-width:1px

    %% Legend on the left
    subgraph LEGEND ["Color Legend"]
        direction TB
        L1(["Emerald = Auth Bridge Service"]):::emerald
        L2(["Sky = Build Pipeline"]):::sky
        L3(["Rose = Script Injection"]):::rose
        L4(["Amber = Prompts Pipeline"]):::amber
        L5(["Violet = Credit Monitoring"]):::violet
        L6(["Cyan = Dynamic Script Loading"]):::cyan
    end
    style LEGEND fill:#1a1a1a,stroke:#555,color:#e0e0e0,stroke-width:1px

    LEGEND ~~~ ROOT

    ROOT(["Marco Extension Architecture"]):::root

    ROOT --> AUTH & BUILD & INJECT & PROMPTS & CREDITS & DYNLOAD

    %% Auth Bridge - Emerald
    AUTH(["Auth Bridge Service"]):::emerald
    AUTH --> A1(["getBearerToken: TTL-cached localStorage"]):::emeraldSub
    AUTH --> A2(["Cookie fallback: read Lovable session"]):::emeraldSub
    AUTH --> A3(["Save token + timestamp to localStorage"]):::emeraldSub

    %% Build Pipeline - Sky
    BUILD(["Macro Controller Build"]):::sky
    BUILD --> B1(["TypeScript Source + Config"]):::skySub
    BUILD --> B2(["Vite IIFE + LESS + Templates"]):::skySub
    BUILD --> B3(["dist/ Output Artifacts"]):::skySub
    B3 --> B4(["Extension Deploy via copyProjectScripts"]):::skySub

    %% Script Injection - Rose
    INJECT(["Script Injection Pipeline"]):::rose
    INJECT --> I0(["Stage 0-1: Deps + Script Resolution"]):::roseSub
    INJECT --> I1(["Stage 1.5: Namespace Bootstrap"]):::roseSub
    INJECT --> I2(["Stage 2: Relay + Token Seeding"]):::roseSub
    INJECT --> I3(["Stage 3-4: IIFE Wrap + CSP Execute"]):::roseSub
    I3 --> I4(["Stage 5: Namespace Registration"]):::roseSub

    %% Prompts Pipeline - Amber
    PROMPTS(["Prompts Pipeline"]):::amber
    PROMPTS --> P1(["Source: prompt folders"]):::amberSub
    PROMPTS --> P2(["Build: MacroPrompts.json"]):::amberSub
    PROMPTS --> P3(["SQLite Seeding + IndexedDB Dual Cache"]):::amberSub
    P3 --> P4(["UI: HtmlCopy for MacroController, JsonCopy for others"]):::amberSub

    %% Credit Monitoring - Violet
    CREDITS(["Credit Monitoring"]):::violet
    CREDITS --> C1(["Call authBridge.getBearerToken"]):::violetSub
    CREDITS --> C2(["GET /user/workspaces with token"]):::violetSub
    C2 --> C3(["Display: scroll + highlight credits"]):::violetSub

    %% Dynamic Script Loading - Cyan
    DYNLOAD(["Dynamic Script Loading"]):::cyan
    DYNLOAD --> D1(["RiseupAsiaMacroExt.require API"]):::cyanSub
    DYNLOAD --> D2(["Validate: allowDynamicRequests + isGlobal"]):::cyanSub
    D2 --> D3(["Background injects target script"]):::cyanSub
    D3 --> D4(["Log to SQLite DynamicLoadLog"]):::cyanSub

    %% Cross-system links
    A3 -.->|"token cached"| A1
    A1 -.->|"bearer token"| C1
    B4 -.->|"scripts deployed"| INJECT
    B3 -.->|"prompts bundled"| P2
    I4 -.->|"namespace ready"| DYNLOAD
    I4 -.->|"RiseupAsiaMacroExt ready"| P3
