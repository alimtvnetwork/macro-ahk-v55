%%{init: {'theme': 'dark', 'themeVariables': {'darkMode': true, 'background': '#222222', 'primaryColor': '#F5A623', 'primaryTextColor': '#1a1a1a', 'lineColor': '#666', 'fontSize': '13px'}}}%%

flowchart TD
    classDef root fill:#F5A623,stroke:#F5A623,color:#1a1a1a,stroke-width:0px,font-weight:bold,font-size:15px
    classDef emerald fill:#10B981,stroke:#10B981,color:#fff,stroke-width:2px,font-weight:bold
    classDef emeraldSub fill:#2a2a2a,stroke:#10B981,color:#e0e0e0,stroke-width:1px
    classDef sky fill:#0EA5E9,stroke:#0EA5E9,color:#fff,stroke-width:2px,font-weight:bold
    classDef skySub fill:#2a2a2a,stroke:#0EA5E9,color:#e0e0e0,stroke-width:1px
    classDef rose fill:#F43F5E,stroke:#F43F5E,color:#fff,stroke-width:2px,font-weight:bold
    classDef roseSub fill:#2a2a2a,stroke:#F43F5E,color:#e0e0e0,stroke-width:1px
    classDef amber fill:#F59E0B,stroke:#F59E0B,color:#1a1a1a,stroke-width:2px,font-weight:bold
    classDef amberSub fill:#2a2a2a,stroke:#F59E0B,color:#e0e0e0,stroke-width:1px
    classDef violet fill:#8B5CF6,stroke:#8B5CF6,color:#fff,stroke-width:2px,font-weight:bold
    classDef violetSub fill:#2a2a2a,stroke:#8B5CF6,color:#e0e0e0,stroke-width:1px
    classDef cyan fill:#06B6D4,stroke:#06B6D4,color:#fff,stroke-width:2px,font-weight:bold
    classDef cyanSub fill:#2a2a2a,stroke:#06B6D4,color:#e0e0e0,stroke-width:1px

    %% Legend on the left
    subgraph LEGEND ["Color Legend"]
        direction TB
        L1(["Emerald = Source Files"]):::emerald
        L2(["Sky = Build Aggregation"]):::sky
        L3(["Rose = Extension Deploy"]):::rose
        L4(["Amber = SQLite Seeding"]):::amber
        L5(["Violet = Runtime Loading"]):::violet
        L6(["Cyan = UI Rendering"]):::cyan
    end
    style LEGEND fill:#1a1a1a,stroke:#555,color:#e0e0e0,stroke-width:1px

    LEGEND ~~~ ROOT

    ROOT(["Prompts Pipeline"]):::root

    ROOT --> SRC & BUILD & DEPLOY & SEED & RUNTIME & UINODE

    %% Source - Emerald (two branches: human prompts + macro-prompts)
    SRC(["Source Files"]):::emerald
    SRC --> SRC_H(["standalone-scripts/prompts/"]):::emeraldSub
    SRC --> SRC_M(["standalone-scripts/macro-prompts/ (NEW)"]):::emeraldSub
    SRC --> SRC_X(["standalone-scripts/macros/ (NEW: .macro.json)"]):::emeraldSub
    SRC_H --> F1(["NNN-slug/"]):::emeraldSub
    SRC_M --> FM(["NNN-slug/ (template, Variables[])"]):::emeraldSub
    F1 --> INFO(["info.json"]):::emeraldSub
    F1 --> MD(["prompt.md"]):::emeraldSub
    FM --> INFOM(["info.json (Variables[], WritesTo)"]):::emeraldSub
    FM --> MDM(["prompt.md (with {{ Placeholders }})"]):::emeraldSub

    %% Build - Sky (dual-bundle emit)
    BUILD(["Build Aggregation"]):::sky
    BUILD --> AGG(["AggregatePrompts.mjs (extended)"]):::skySub
    AGG --> OUT(["chrome-extension/prompts/prompts.json"]):::skySub
    AGG --> OUT_M(["chrome-extension/macro-prompts/macro-prompts.json (NEW)"]):::skySub
    AGG --> OUT_X(["chrome-extension/macros/macros.json (NEW)"]):::skySub

    %% Deploy - Rose
    DEPLOY(["Extension Deploy"]):::rose
    DEPLOY --> COPY(["ViteStaticCopy plugin"]):::roseSub
    COPY --> EXT(["chrome-extension/dist/prompts/"]):::roseSub
    EXT --> WAR(["WebAccessibleResources"]):::roseSub

    %% Seeding - Amber
    SEED(["SQLite Seeding"]):::amber
    SEED --> LOAD(["LoadBundledDefaultPrompts"]):::amberSub
    LOAD --> HASH(["Version hash: Count-Hash36"]):::amberSub
    HASH --> UPSERT(["Seed / Upsert prompts"]):::amberSub
    UPSERT --> DB(["Prompts + PromptsCategory tables"]):::amberSub

    %% Runtime Loading - Violet
    RUNTIME(["Runtime Loading"]):::violet
    RUNTIME --> OPEN(["User opens Prompt menu"]):::violetSub
    OPEN --> IDBCHECK(["Check IndexedDB for cached data"]):::violetSub
    IDBCHECK -->|"Cache hit"| USECACHE(["Use cached copy directly"]):::violetSub
    IDBCHECK -->|"Cache miss"| FETCHDB(["GetPrompts bridge to SQLite"]):::violetSub
    FETCHDB --> WRITEIDB(["Write dual cache to IndexedDB"]):::violetSub
    WRITEIDB --> USECACHE

    RUNTIME --> RELOAD(["User clicks Load button in menu"]):::violetSub
    RELOAD --> FORCEDB(["Force GetPrompts from SQLite"]):::violetSub
    FORCEDB --> OVERWRITE(["Overwrite IndexedDB dual cache"]):::violetSub
    OVERWRITE --> REFRESH(["Re-render with fresh data"]):::violetSub

    RUNTIME --> DUALCACHE(["Dual Cache in IndexedDB"]):::violetSub
    DUALCACHE --> CACHE_JSON(["JsonCopy: raw JSON prompt array"]):::violetSub
    DUALCACHE --> CACHE_HTML(["HtmlCopy: pre-rendered HTML snapshot"]):::violetSub

    %% UI Rendering - Cyan
    UINODE(["UI Rendering"]):::cyan
    UINODE --> PICK(["Pick cache version to render"]):::cyanSub
    CACHE_HTML -.->|"MacroController uses HTML"| PICK
    CACHE_JSON -.->|"Other consumers use JSON"| PICK
    PICK --> DROP(["Prompt Dropdown Panel"]):::cyanSub
    DROP --> INJECT(["Paste into editor"]):::cyanSub

    %% Cross-flow links
    OUT -.->|"copied"| COPY
    OUT_M -.->|"copied (NEW branch)"| COPY
    OUT_X -.->|"copied (NEW branch)"| COPY
    WAR -.->|"getURL"| LOAD
    DB -.->|"GetPrompts"| FETCHDB
    DB -.->|"GetPrompts"| FORCEDB
    USECACHE -.->|"cached data"| PICK
