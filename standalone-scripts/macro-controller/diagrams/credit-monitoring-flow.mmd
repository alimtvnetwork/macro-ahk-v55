%%{init: {'theme': 'dark', 'themeVariables': {'darkMode': true, 'background': '#222222', 'primaryColor': '#F5A623', 'primaryTextColor': '#1a1a1a', 'lineColor': '#666', 'fontSize': '13px'}}}%%

flowchart TD
    classDef root fill:#F5A623,stroke:#F5A623,color:#1a1a1a,stroke-width:0px,font-weight:bold,font-size:15px
    classDef emerald fill:#10B981,stroke:#10B981,color:#fff,stroke-width:2px,font-weight:bold
    classDef emeraldSub fill:#2a2a2a,stroke:#10B981,color:#e0e0e0,stroke-width:1px
    classDef sky fill:#0EA5E9,stroke:#0EA5E9,color:#fff,stroke-width:2px,font-weight:bold
    classDef skySub fill:#2a2a2a,stroke:#0EA5E9,color:#e0e0e0,stroke-width:1px
    classDef rose fill:#F43F5E,stroke:#F43F5E,color:#fff,stroke-width:2px,font-weight:bold
    classDef roseSub fill:#2a2a2a,stroke:#F43F5E,color:#e0e0e0,stroke-width:1px
    classDef amber fill:#F59E0B,stroke:#F59E0B,color:#1a1a1a,stroke-width:2px,font-weight:bold
    classDef amberSub fill:#2a2a2a,stroke:#F59E0B,color:#e0e0e0,stroke-width:1px
    classDef violet fill:#8B5CF6,stroke:#8B5CF6,color:#fff,stroke-width:2px,font-weight:bold
    classDef violetSub fill:#2a2a2a,stroke:#8B5CF6,color:#e0e0e0,stroke-width:1px

    %% Legend on the left
    subgraph LEGEND ["Color Legend"]
        direction TB
        L1(["Emerald = Auth Bridge Token"]):::emerald
        L2(["Sky = API Request"]):::sky
        L3(["Rose = Display Results"]):::rose
        L4(["Violet = Retry via Cookie Refresh"]):::violet
        L5(["Amber = Final Error"]):::amber
    end
    style LEGEND fill:#1a1a1a,stroke:#555,color:#e0e0e0,stroke-width:1px

    LEGEND ~~~ ROOT

    ROOT(["Credit Monitoring Flow"]):::root

    ROOT --> CLICK

    %% Step 1 - User triggers, get token via Auth Bridge (Emerald)
    CLICK(["Step 1: User Clicks Credits"]):::emerald
    CLICK --> PREP(["Prepare request: URL + body"]):::emeraldSub
    PREP --> ASK(["Call authBridge.getBearerToken"]):::emeraldSub
    ASK --> TTLCHECK(["Auth Bridge checks token age vs TTL config"]):::emeraldSub
    TTLCHECK -->|"Fresh: within TTL"| CACHED(["Return cached localStorage token"]):::emeraldSub
    TTLCHECK -->|"Stale: exceeds TTL"| COOKIEREAD(["Read lovable-session-id cookie"]):::emeraldSub
    COOKIEREAD --> SAVE(["Save new token + timestamp to localStorage"]):::emeraldSub
    SAVE --> CACHED

    %% Step 2 - First API request (Sky)
    CACHED --> APICALL(["Step 2: API Request"]):::sky
    APICALL --> REQ(["GET /user/workspaces with bearer token"]):::skySub
    REQ -->|"Success"| DISPLAY
    REQ -->|"401 / 403 / Network Error"| RETRY

    %% Step 3 - Retry: force-refresh token from cookie (Violet)
    RETRY(["Step 3: Retry — Force Token Refresh"]):::violet
    RETRY --> FORCE(["Call authBridge.getBearerToken with force flag"]):::violetSub
    FORCE --> COOKIE2(["Auth Bridge reads cookie, ignores TTL cache"]):::violetSub
    COOKIE2 --> SAVE2(["Save fresh token + timestamp to localStorage"]):::violetSub
    SAVE2 --> REQ2(["Retry GET /user/workspaces with new token"]):::violetSub
    REQ2 -->|"Success"| DISPLAY
    REQ2 -->|"Fails again"| FAIL

    %% Step 4 - Display results (Rose)
    DISPLAY(["Step 4: Display Data"]):::rose
    DISPLAY --> FIND(["Find current workspace via WsCurrentName"]):::roseSub
    FIND --> SCROLL(["Scroll to current workspace"]):::roseSub
    SCROLL --> HIGHLIGHT(["Highlight credits with amber outline"]):::roseSub
    DISPLAY --> UPDATE(["Update credit display values"]):::roseSub

    %% Step 5 - Final error, no more retries (Amber)
    FAIL(["Step 5: Final Error — No More Retries"]):::amber
    FAIL --> TOAST(["Show error toast with copy button"]):::amberSub
    TOAST --> COPY(["User can copy error details"]):::amberSub
