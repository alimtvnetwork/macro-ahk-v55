{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riseup.asia/schemas/macro-definition#v1",
  "title": "MacroDefinition",
  "type": "object",
  "required": ["Slug", "Version", "Title", "Steps"],
  "properties": {
    "Slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" },
    "Version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "Title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "Description": { "type": "string", "maxLength": 1000 },
    "Categories": { "type": "array", "items": { "type": "string" }, "maxItems": 10 },
    "DefaultVariables": { "type": "object", "additionalProperties": true },
    "TargetScore": { "type": "integer", "minimum": 1, "maximum": 100, "default": 100 },
    "MaxLoops": { "type": "integer", "minimum": 1, "maximum": 20, "default": 5 },
    "Steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": { "$ref": "#/$defs/Step" }
    }
  },
  "$defs": {
    "Step": {
      "type": "object",
      "required": ["StepKindId"],
      "properties": {
        "StepKindId": { "type": "integer", "minimum": 1, "maximum": 8 },
        "PromptSlug": { "type": "string" },
        "Variables": { "type": "object", "additionalProperties": true },
        "Count": { "type": "integer", "minimum": 1, "maximum": 200 },
        "Condition": { "type": "string" },
        "GotoStep": { "type": "integer", "minimum": 0 },
        "WriteTo": { "type": "string" },
        "Label": { "type": "string", "maxLength": 80 }
      }
    }
  },
  "additionalProperties": false
}
