      "mustHaveOverview": false
    },
    {
      "path": "spec/99-archive/imported-powershell-integration",
      "kind": "archive-container",
      "mustHaveOverview": false
    },
    {
      "path": "spec/99-archive/imported-powershell-integration/powershell-integration",
      "kind": "archive-leaf",
      "mustHaveOverview": false
    },
    {
      "path": "spec/99-archive/wordpress",
      "kind": "archive-container",
      "mustHaveOverview": false
    },
    {
      "path": "spec/99-archive/wordpress/wordpress-plugin",
      "kind": "archive-leaf",
      "mustHaveOverview": false
    },
    {
      "path": "spec/99-archive/wordpress/wordpress-plugin-development",
      "kind": "archive-leaf",
      "mustHaveOverview": false
    },
    {
      "path": "spec/99-archive/wordpress/wp-plugin-publish",
      "kind": "archive-leaf",
      "mustHaveOverview": false
    },
    {
      "path": "spec/validation-reports",
      "kind": "governance",
      "mustHaveOverview": false
    }
  ]
}
