      "mustHaveOverview": false
    },
    {
      "path": "spec/99-archive/duplicates/03-coding-guidelines-stale",
      "kind": "archive-leaf",
      "mustHaveOverview": false
    },
    {
      "path": "spec/99-archive/duplicates/04-error-manage-spec-stale",
