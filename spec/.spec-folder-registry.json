      "mustHaveOverview": false,
      "note": "Always preserve; historical content"
    },
    {
      "path": "spec/99-archive/duplicates",
      "kind": "archive-container",
      "mustHaveOverview": false
    },
    {
      "path": "spec/99-archive/duplicates/02-spec-authoring-guide-stale",
