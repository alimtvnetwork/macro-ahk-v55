{
  "$schema": "./.spec-folder-registry.schema.json",
  "version": "1.0.0",
  "purpose": "Authoritative list of spec/ subfolders that must always exist. Used by scripts/spec-folder-guard.mjs to detect/repair auto-cleanup damage.",
  "lastVerified": "2026-06-04",
  "policy": {
    "sentinelFile": ".lovable-keep",
    "atRiskDefinition": "Any directory inside spec/ that contains zero direct files (only subdirectories or empty). Sentinels prevent these from being treated as empty.",
    "neverPrune": [
      "spec/99-archive/**",
      "spec/validation-reports/**"
    ]
  },
  "requiredFolders": [
    {
      "path": "spec/01-spec-authoring-guide",
      "kind": "core",
      "mustHaveOverview": true
    },
    {
      "path": "spec/02-coding-guidelines",
      "kind": "core",
      "mustHaveOverview": true
    },
    {
      "path": "spec/03-error-manage",
      "kind": "core",
      "mustHaveOverview": true
    },
    {
      "path": "spec/04-database-conventions",
      "kind": "core",
      "mustHaveOverview": true
    },
    {
      "path": "spec/05-split-db-architecture",
      "kind": "core",
      "mustHaveOverview": true
    },
    {
      "path": "spec/06-seedable-config-architecture",
      "kind": "core",
      "mustHaveOverview": true
    },
    {
      "path": "spec/07-design-system",
      "kind": "core",
      "mustHaveOverview": true
    },
    {
      "path": "spec/08-docs-viewer-ui",
      "kind": "core-stub",
      "mustHaveOverview": true
    },
    {
      "path": "spec/09-code-block-system",
      "kind": "core-stub",
      "mustHaveOverview": true
    },
    {
      "path": "spec/10-research",
      "kind": "core-stub",
      "mustHaveOverview": true
    },
    {
      "path": "spec/11-powershell-integration",
      "kind": "core",
      "mustHaveOverview": true
    },
    {
      "path": "spec/12-cicd-pipeline-workflows",
      "kind": "core",
      "mustHaveOverview": true
    },
    {
      "path": "spec/2026-spec",
      "kind": "dated-spec-root",
      "mustHaveOverview": false
    },
    {
      "path": "spec/2026-spec/02-ci-cd-spec-for-chrome-extensions",
      "kind": "dated-spec-leaf",
      "mustHaveOverview": false,
      "note": "Canonical Chrome-extension CI/CD spec; indexed by spec/12-cicd-pipeline-workflows/"
    },
    {
      "path": "spec/14-update",
      "kind": "core-stub",
      "mustHaveOverview": true
    },
    {
      "path": "spec/17-consolidated-guidelines",
      "kind": "core-stub",
      "mustHaveOverview": true
    },
    {
      "path": "spec/21-app",
      "kind": "app-root",
      "mustHaveOverview": true
    },
    {
      "path": "spec/21-app/02-features",
      "kind": "app-container",
      "mustHaveOverview": true
    },
    {
      "path": "spec/21-app/04-design-diagrams",
      "kind": "app-sparse",
      "mustHaveOverview": false,
      "note": "Only contains subdirectory mermaid-design-diagram-spec/ — at-risk"
    },
    {
      "path": "spec/21-app/04-design-diagrams/mermaid-design-diagram-spec",
      "kind": "app-leaf",
      "mustHaveOverview": false
    },
    {
      "path": "spec/22-app-issues",
      "kind": "app",
      "mustHaveOverview": true
    },
    {
      "path": "spec/23-database",
      "kind": "core",
      "mustHaveOverview": true
    },
    {
      "path": "spec/23-database/diagrams",
      "kind": "core",
      "mustHaveOverview": false
