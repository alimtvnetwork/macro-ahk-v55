%% Overall combined schema ERD
%% Spans the Extension DB (logs/errors/prompts/updater/shared assets)
%% and the per-Project Recorder DB (data sources, steps, selectors,
%% replay runs, step-group library). Cross-DB links are shown via
%% string IDs (ProjectId, StepId references in logs/errors).
erDiagram
    %% ---------- Extension DB ----------
    Sessions ||--o{ Logs              : "emits"
    Sessions ||--o{ Errors            : "emits"
    Logs     ||--o| Errors            : "linked via LogId"
    Errors   }o--|| ErrorCodes        : "classified by"

    Prompts          ||--o{ PromptsToCategory : "tagged"
    PromptsCategory  ||--o{ PromptsToCategory : "tagged"

    UpdaterInfo      ||--o{ UpdaterToCategory : "tagged"
    UpdaterCategory  ||--o{ UpdaterToCategory : "tagged"
    UpdaterInfo      ||--o{ UpdaterEndpoints  : "owns"
    UpdaterInfo      ||--o{ UpdaterSteps      : "owns"

    SharedAsset      ||--o{ AssetVersion      : "history"

    %% ---------- Project / Recorder DB ----------
    Project    ||--o{ StepGroup        : "owns"
    StepGroup  ||--o{ StepGroup        : "nests (max 8)"
    StepGroup  ||--o{ Step             : "contains"
    StepKind   ||--o{ Step             : "classifies"
    StepStatus ||--o{ Step             : "classifies"
    Step       ||--o{ Selector         : "uses"
    Selector   ||--o| Selector         : "anchored by"
    Step       ||--o| FieldBinding     : "may bind"
    DataSource ||--o{ FieldBinding     : "supplies"
    DataSourceKind ||--o{ DataSource   : "classifies"
    SelectorKind   ||--o{ Selector     : "classifies"
    Step       ||--o{ StepTag          : "tagged"
    ReplayRun  ||--o{ ReplayStepResult : "contains"
    Step       ||--o{ ReplayStepResult : "scored"

    %% ---------- Cross-DB soft links (string IDs, no FK) ----------
    Project ||..o{ Logs   : "ProjectId (soft)"
    Project ||..o{ Errors : "ProjectId (soft)"

    %% Minimal attribute set — full attributes live in 01/02/03 diagrams.
    Sessions {
        INTEGER Id PK
        TEXT    StartedAt
        TEXT    Version
    }
    Logs {
        INTEGER Id PK
        INTEGER SessionId FK
        TEXT    Level
        TEXT    Category
        TEXT    ProjectId
    }
    Errors {
        INTEGER Id PK
        INTEGER SessionId FK
        INTEGER LogId FK
        TEXT    ErrorCode FK
        TEXT    ProjectId
    }
    ErrorCodes {
        TEXT Code PK
        TEXT Severity
    }
    Prompts            { INTEGER Id PK   TEXT Slug   TEXT Name }
    PromptsCategory    { INTEGER Id PK   TEXT Name }
    PromptsToCategory  { INTEGER Id PK   INTEGER PromptId FK   INTEGER CategoryId FK }
    UpdaterInfo        { INTEGER Id PK   TEXT Name   TEXT CurrentVersion }
    UpdaterCategory    { INTEGER Id PK   TEXT Name }
    UpdaterToCategory  { INTEGER Id PK   INTEGER UpdaterId FK   INTEGER CategoryId FK }
    UpdaterEndpoints   { INTEGER Id PK   INTEGER UpdaterId FK   TEXT Url }
    UpdaterSteps       { INTEGER Id PK   INTEGER UpdaterId FK   TEXT Type }
    SharedAsset        { INTEGER Id PK   TEXT AssetKey }
    AssetVersion       { INTEGER Id PK   INTEGER SharedAssetId FK   TEXT CreatedAt }

    Project {
        INTEGER ProjectId PK
        TEXT    ProjectExternalId
        TEXT    Name
    }
    StepGroup {
        INTEGER StepGroupId PK
        INTEGER ProjectId FK
        INTEGER ParentStepGroupId FK
        TEXT    Name
    }
    StepKind        { INTEGER StepKindId PK   TEXT Name }
    StepStatus      { INTEGER StepStatusId PK TEXT Name }
    DataSourceKind  { INTEGER DataSourceKindId PK TEXT Name }
    SelectorKind    { INTEGER SelectorKindId PK   TEXT Name }
    DataSource {
        INTEGER DataSourceId PK
        INTEGER DataSourceKindId FK
        TEXT    FilePath
    }
    Step {
        INTEGER StepId PK
        INTEGER StepGroupId FK
        INTEGER StepKindId FK
        INTEGER StepStatusId FK
        INTEGER OrderIndex
        TEXT    Label
        TEXT    OnSuccessProjectId
        TEXT    OnFailureProjectId
    }
    StepTag {
        INTEGER StepTagId PK
        INTEGER StepId FK
        TEXT    Name
    }
    Selector {
        INTEGER SelectorId PK
        INTEGER StepId FK
        INTEGER SelectorKindId FK
        INTEGER AnchorSelectorId FK
        TEXT    Expression
    }
    FieldBinding {
        INTEGER FieldBindingId PK
        INTEGER StepId FK
        INTEGER DataSourceId FK
        TEXT    ColumnName
    }
    ReplayRun {
        INTEGER ReplayRunId PK
        TEXT    StartedAt
        INTEGER OkSteps
        INTEGER FailedSteps
    }
    ReplayStepResult {
        INTEGER ReplayStepResultId PK
        INTEGER ReplayRunId FK
        INTEGER StepId FK
        INTEGER IsOk
        INTEGER DurationMs
    }
