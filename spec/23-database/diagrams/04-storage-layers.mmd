%%{init: {'theme': 'dark', 'themeVariables': {'darkMode': true, 'background': '#222222', 'primaryColor': '#F5A623', 'primaryTextColor': '#1a1a1a', 'lineColor': '#666', 'fontSize': '13px'}}}%%

flowchart TD
    classDef root fill:#F5A623,stroke:#F5A623,color:#1a1a1a,stroke-width:0px,font-weight:bold,font-size:15px
    classDef emerald fill:#10B981,stroke:#10B981,color:#fff,stroke-width:2px,font-weight:bold
    classDef emeraldSub fill:#2a2a2a,stroke:#10B981,color:#e0e0e0,stroke-width:1px
    classDef sky fill:#0EA5E9,stroke:#0EA5E9,color:#fff,stroke-width:2px,font-weight:bold
    classDef skySub fill:#2a2a2a,stroke:#0EA5E9,color:#e0e0e0,stroke-width:1px
    classDef rose fill:#F43F5E,stroke:#F43F5E,color:#fff,stroke-width:2px,font-weight:bold
    classDef roseSub fill:#2a2a2a,stroke:#F43F5E,color:#e0e0e0,stroke-width:1px
    classDef amber fill:#F59E0B,stroke:#F59E0B,color:#1a1a1a,stroke-width:2px,font-weight:bold
    classDef amberSub fill:#2a2a2a,stroke:#F59E0B,color:#e0e0e0,stroke-width:1px
    classDef violet fill:#8B5CF6,stroke:#8B5CF6,color:#fff,stroke-width:2px,font-weight:bold
    classDef violetSub fill:#2a2a2a,stroke:#8B5CF6,color:#e0e0e0,stroke-width:1px
    classDef limeSub fill:#2a2a2a,stroke:#84CC16,color:#e0e0e0,stroke-width:1px
    classDef warnSub fill:#2a2a2a,stroke:#EF4444,color:#EF4444,stroke-width:1px,font-weight:bold

    ROOT(["DataStorageSchema"]):::root
    ROOT --> SQLITE & IDB & LS & CHROME & SYNC

    SQLITE(["SQLite — ExtensionDB + ProjectDB"]):::emerald
    SQLITE --> EXT_DB(["logs.db: Sessions, Logs, Errors, Prompts, Updater*, SharedAsset, AssetVersion"]):::emeraldSub
    SQLITE --> PROJ_DB(["projectDb: DataSource, Step, StepTag, Selector, FieldBinding, JsSnippet, ReplayRun, ReplayStepResult"]):::emeraldSub
    SQLITE --> SQL_LIMIT(["Limit: Unlimited — in-memory via sql.js"]):::limeSub
    SQLITE --> SQL_CLEAN(["CCleaner: Safe — stored inside extension bundle"]):::limeSub

    IDB(["IndexedDB — ClientCache"]):::sky
    IDB --> IDB_DB(["DB: MarcoPromptsCache v2"]):::skySub
    IDB_DB --> IDB_PS(["Store: Prompts — KeyPath: Id"]):::skySub
    IDB_DB --> IDB_UI(["Store: UiSnapshots — KeyPath: Id"]):::skySub
    IDB --> IDB_LIMIT(["Limit: Dynamic — browser-managed, up to GBs"]):::limeSub
    IDB --> IDB_CLEAN(["CCleaner: REMOVED — treated as site data"]):::warnSub

    LS(["LocalStorage — Tokens + Settings"]):::rose
    LS --> LS_AUTH(["MarcoBearerToken + MarcoTokenSavedAt"]):::roseSub
    LS --> LS_THEME(["MarcoThemePreset — Dark only"]):::roseSub
    LS --> LS_REINJECT(["ReinjectState — HotReload flags"]):::roseSub
    LS --> LS_LIMIT(["Limit: 5 MB per origin"]):::limeSub
    LS --> LS_CLEAN(["CCleaner: REMOVED — treated as site data"]):::warnSub

    CHROME(["ChromeStorage.Local — Extension"]):::amber
    CHROME --> CH_SCRIPTS(["ScriptManifest + FilePaths"]):::amberSub
    CHROME --> CH_SETTINGS(["ExtensionSettings + Toggles"]):::amberSub
    CHROME --> CH_PROJ(["PerProjectConfig overrides"]):::amberSub
    CHROME --> CH_LIMIT(["Limit: 10 MB default, Unlimited with permission"]):::limeSub
    CHROME --> CH_CLEAN(["CCleaner: Safe — extension data is protected"]):::limeSub

    SYNC(["CacheInvalidation"]):::violet
    SYNC --> INV_PROMPT(["PromptSave/Delete clears IndexedDB"]):::violetSub
    SYNC --> INV_DEPLOY(["Deploy clears LocalStorage tokens"]):::violetSub
    SYNC --> INV_SEED(["FirstBoot seeds from MacroPrompts.json"]):::violetSub
